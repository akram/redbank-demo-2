OPENAI_API_KEY=
LLM_BASE_URL=https://your-vllm-or-openai.example.com/v1
LLM_MODEL=your-model-id

# --- MCP server ---
MCP_SERVER_URL=http://redbank-mcp-server:8000/mcp

